# Copy this file to .env and fill in real values
# The .env file is gitignored — never commit real credentials

# ========================================
# Coinbase Advanced Trade API credentials
# ========================================
# Generate at: Coinbase → Settings → API → Create new API key
# Start with VIEW permission only. Add TRADE permission only when ready to go live.
# NEVER enable TRANSFER permission.
COINBASE_API_KEY_NAME=organizations/your-org-id/apiKeys/your-key-id
COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nyour-key-here\n-----END EC PRIVATE KEY-----\n"

# ========================================
# Bot operational mode
# ========================================
# Valid values: backtest, paper, live
# DO NOT set this to "live" until you've completed 30+ days of paper trading
BOT_MODE=paper

# ========================================
# Capital configuration
# ========================================
# Total capital allocated to the bot, in USD
# Used for position sizing and the kill switch
ACCOUNT_CAPITAL_USD=10000

# ========================================
# Storage paths
# ========================================
# Where parquet data files are written
DATA_DIR=/home/ubuntu/crypto-momentum-bot/data
LOGS_DIR=/home/ubuntu/crypto-momentum-bot/logs

# ========================================
# Redis (for runtime state)
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========================================
# Alerting (optional, but recommended)
# ========================================
# For sending alerts when kill switch fires, consecutive losses, errors
# Leave blank to disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ========================================
# Logging
# ========================================
# Valid: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
